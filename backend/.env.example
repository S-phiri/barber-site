# Dev uses SQLite by default. For Supabase/Postgres set DB_ENGINE=postgres and fill details.
# DB CONFIG
# DB_ENGINE=postgres
# DB_NAME=postgres
# DB_USER=YOUR_SUPABASE_USER
# DB_PASSWORD=YOUR_SUPABASE_PASSWORD
# DB_HOST=YOUR_PROJECT.supabase.co
# DB_PORT=5432

# Google OAuth (create OAuth 2.0 Web creds in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/barber/google-calendar/callback/
# Target calendar to write events into (primary or a specific calendar ID)
GOOGLE_CALENDAR_ID=primary